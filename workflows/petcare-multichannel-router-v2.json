    {
      "parameters": {
        "jsCode": "const original = $('Build Triage Prompts').first().json;\nconst raw = $json;\nconst candidates = [\n  raw.text,\n  raw.content,\n  raw.message,\n  raw.output,\n  raw.response,\n  raw.data,\n  raw.choices?.[0]?.message?.content\n].filter(Boolean);\nlet triage = candidates[0] || raw;\nif (typeof triage === 'string') {\n  triage = JSON.parse(triage);\n}\nconst allowedCategories = ['URGENCIA', 'AGENDAMIENTO', 'CONSULTA', 'SEGUIMIENTO', 'ADMINISTRATIVA'];\nconst allowedPriorities = ['ALTA', 'MEDIA', 'BAJA'];\nif (!allowedCategories.includes(triage.categoria)) {\n  throw new Error(`Invalid categoria: ${triage.categoria}`);\n}\nif (!allowedPriorities.includes(triage.prioridad)) {\n  throw new Error(`Invalid prioridad: ${triage.prioridad}`);\n}\nif (!triage.justificacion) {\n  throw new Error('Missing justificacion');\n}\nreturn [{ json: { ...original, ...triage } }];"
      },
