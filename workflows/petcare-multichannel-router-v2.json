      "parameters": {
        "jsCode": "const message = $json.message || {};\nconst from = message.from || {};\nconst text = message.text || message.caption || '';\nreturn [{\n  json: {\n    channel: 'telegram',\n    source: 'telegram',\n    user_id: String(from.id || ''),\n    user_name: [from.first_name, from.last_name].filter(Boolean).join(' ').trim() || from.username || 'unknown',\n    contact: from.username ? `@${from.username}` : '',\n    message_text: text,\n    timestamp: new Date(($json.message?.date || Math.floor(Date.now() / 1000)) * 1000).toISOString(),\n    attachments: [],\n    raw_payload: $json\n  }\n}];"
      },
      "id": "normalize-telegram",
      "name": "Normalize Telegram",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        180
      ]
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nreturn [{\n  json: {\n    channel: body.channel || 'webhook',\n    source: 'webhook',\n    user_id: String(body.user_id || body.email || body.phone || 'anonymous'),\n    user_name: body.user_name || body.name || 'unknown',\n    contact: body.contact || body.email || body.phone || '',\n    message_text: body.message_text || body.message || body.text || '',\n    timestamp: body.timestamp || new Date().toISOString(),\n    attachments: body.attachments || [],\n    raw_payload: $json\n  }\n}];"
      },
