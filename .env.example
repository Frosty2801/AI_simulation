N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Public HTTPS URL that ngrok will expose for n8n
N8N_PUBLIC_URL=
N8N_PUBLIC_HOST=
N8N_PROTOCOL=https

# Ngrok auth token
NGROK_AUTHTOKEN=

# Embeddings provider: openai | ollama
EMBEDDING_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=
